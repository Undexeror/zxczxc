package sqwore.deko.Notifications;

import org.apache.hc.client5.http.auth.AuthScope;
import org.apache.hc.client5.http.auth.UsernamePasswordCredentials;
import org.apache.hc.client5.http.impl.auth.BasicCredentialsProvider;
import org.apache.hc.client5.http.impl.classic.HttpClients;
import org.apache.hc.client5.http.impl.io.PoolingHttpClientConnectionManagerBuilder;
import org.apache.hc.core5.http.HttpHost;
import org.springframework.beans.factory.annotation.Value;
import org.springframework.http.client.HttpComponentsClientHttpRequestFactory;
import org.springframework.stereotype.Service;
import org.springframework.web.client.RestTemplate;
import sqwore.deko.DTO.CreateOrderRequest;

import java.net.InetSocketAddress;
import java.net.Proxy;

@Service
public class TelegramNotificationService {

    @Value("${telegram.bot.token}")
    private String botToken;

    @Value("${telegram.chat.id}")
    private String chatId;

    private final RestTemplate restTemplate;

    // ←←←←←←←←←←←←←←←←←←←←←←←←←←←←←←←←
    // НАСТРОЙКИ ПРОКСИ С ЛОГИНОМ И ПАРОЛЕМ
    private final String proxyHost = "IP_ПРОКСИ";      // например: 123.45.67.89
    private final int proxyPort = 12345;               // порт прокси
    private final String proxyUsername = "твой_логин";
    private final String proxyPassword = "твой_пароль";

    public TelegramNotificationService() {
        // Создаём credentials
        BasicCredentialsProvider credentialsProvider = new BasicCredentialsProvider();
        credentialsProvider.setCredentials(
                new AuthScope(proxyHost, proxyPort),
                new UsernamePasswordCredentials(proxyUsername, proxyPassword.toCharArray())
        );

        // Создаём HttpClient с прокси и авторизацией
        var httpClient = HttpClients.custom()
                .setProxy(new HttpHost(proxyHost, proxyPort))
                .setDefaultCredentialsProvider(credentialsProvider)
                .setConnectionManager(PoolingHttpClientConnectionManagerBuilder.create().build())
                .build();

        HttpComponentsClientHttpRequestFactory factory = new HttpComponentsClientHttpRequestFactory(httpClient);

        this.restTemplate = new RestTemplate(factory);
    }

    public void sendOrderNotification(CreateOrderRequest request) {
        String message = """
                Новый заказ в STEAMTOP!

                Логин: %s
                Сумма: %s %s
                К оплате: %s ₽
                """.formatted(
                request.getInfo(),
                request.getAmount(),
                request.getCurrency(),
                request.getRubAmount() != null ? request.getRubAmount() : "—"
        );

        String url = "https://api.telegram.org/bot" + botToken + 
                     "/sendMessage?chat_id=" + chatId + "&text=" + message;

        try {
            String response = restTemplate.getForObject(url, String.class);
            System.out.println("Telegram: сообщение отправлено успешно");
        } catch (Exception e) {
            System.err.println("Ошибка отправки в Telegram:");
            e.printStackTrace();
        }
    }
}
<script th:inline="javascript">
    window.onload = function() {
        const successMsg = /*[[${success}]]*/ '';
        const errorMsg   = /*[[${error}]]*/ '';

        if (successMsg) {
            showModal(true, successMsg);
        } else if (errorMsg) {
            showModal(false, errorMsg);
        }
    };

    function showModal(isSuccess, message) {
        const modal = document.getElementById('orderModal');
        const successImg = document.getElementById('successImage');
        const errorImg = document.getElementById('errorImage');
        const title = document.getElementById('modalTitle');
        const msg = document.getElementById('modalMessage');

        if (isSuccess) {
            successImg.classList.remove('hidden');
            errorImg.classList.add('hidden');
            title.textContent = 'Успешно!';
            title.style.color = '#34d399';
        } else {
            successImg.classList.add('hidden');
            errorImg.classList.remove('hidden');
            title.textContent = 'Ошибка';
            title.style.color = '#f87171';
        }

        msg.textContent = message;
        modal.classList.remove('hidden');

        // Автозакрытие через 4.5 секунды
        setTimeout(closeModal, 4500);
    }

    function closeModal() {
        document.getElementById('orderModal').classList.add('hidden');
    }
</script>
